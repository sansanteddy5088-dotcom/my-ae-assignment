#include<stdio.h>    // Library standar untuk input/output (printf, scanf)
#include<stdlib.h>   // Library standar untuk alokasi memori (malloc, free)
#include<string.h>   // Library standar untuk manipulasi string (strcpy)

// Struktur node AVL
struct tnode{
    char id[10];              // ID node (string max 9 karakter + '\0')
    float fuel;               // Nilai bahan bakar (kunci utama AVL)
    int distance;             // Jarak (kunci kedua jika fuel sama)
    int height;               // Tinggi node (untuk AVL balancing)
    struct tnode *left, *right; // Pointer ke anak kiri dan kanan
}*root = NULL;                // Root pohon AVL, awalnya NULL (kosong)

// Membuat node baru
struct tnode *createnode(char id[], float fuel, int distance){
    struct tnode *node = (struct tnode*)malloc(sizeof(struct tnode)); // Alokasi memori
    strcpy(node->id, id);      // Salin string ID ke node
    node->fuel = fuel;         // Isi nilai fuel
    node->distance = distance; // Isi nilai distance
    node->height = 1;          // Node baru selalu tinggi = 1
    node->left = node->right = NULL; // Anak kiri dan kanan kosong
    return node;               // Kembalikan pointer node baru
}

// Mengembalikan tinggi node, jika NULL → 0
int height(struct tnode *n){
    return n ? n->height : 0;
}

// Hitung balance factor = tinggi kiri - tinggi kanan
int balance(struct tnode *n){
    return n ? height(n->left) - height(n->right) : 0;
}

// Fungsi max sederhana
int max(int a, int b){
    return a>b ? a:b;
}

// Rotasi kanan (LL case)
struct tnode *rotateright(struct tnode *y){
    struct tnode *x = y->left;   // Ambil anak kiri
    struct tnode *T = x->right;  // Simpan anak kanan dari x
    
    x->right = y;                // Putar: x jadi root, y turun ke kanan
    y->left = T;                 // Anak kanan x jadi anak kiri y
    
    // Update tinggi node
    y->height = 1 + max(height(y->left), height(y->right));
    x->height = 1 + max(height(x->left), height(x->right));

    return x;                    // Return root baru
}

// Rotasi kiri (RR case)
struct tnode *rotateleft(struct tnode *x){
    struct tnode *y = x->right;  // Ambil anak kanan
    struct tnode *T = y->left;   // Simpan anak kiri dari y
    
    y->left = x;                 // Putar: y jadi root, x turun ke kiri
    x->right = T;                // Anak kiri y jadi anak kanan x
    
    // Update tinggi node
    x->height = 1 + max(height(x->left), height(x->right));
    y->height = 1 + max(height(y->left), height(y->right));
    
    return y;                    // Return root baru
}

// Insert node ke AVL
struct tnode *insert(struct tnode *node, char id[], float fuel, int distance){
    if(!node) return createnode(id,fuel,distance); // Jika kosong, buat node baru
    
    // Aturan BST berdasarkan fuel
    if(fuel < node->fuel) node->left = insert(node->left, id, fuel, distance);
    else if(fuel > node->fuel) node->right = insert(node->right, id, fuel, distance);
    else{ // Jika fuel sama → bandingkan distance
        if(distance > node->distance) node->left = insert(node->left,id,fuel,distance);
        else if(distance < node->distance) node->right = insert(node->right, id, fuel, distance);
    }
    
    // Update tinggi node
    node->height = 1 + max(height(node->left), height(node->right));
    int bf = balance(node); // Hitung balance factor
    
    // Cek kasus imbalance dan lakukan rotasi
    if(bf > 1 && fuel < node->left->fuel) return rotateright(node); // LL
    if(bf > 1 && fuel > node->left->fuel){ node->left = rotateleft(node->left); return rotateright(node);} // LR
    if(bf < -1 && fuel > node->right->fuel) return rotateleft(node); // RR
    if(bf < -1 && fuel < node->right->fuel){ node->right = rotateright(node->right); return rotateleft(node);} // RL
    
    return node; // Return node yang sudah seimbang
}

// Extract node paling kiri (nilai fuel terkecil)
struct tnode *extract (struct tnode *node){
    if(!node)return NULL; // Jika kosong
    
    if(!node->left){      // Jika tidak ada anak kiri → node ini paling kecil
        struct tnode *r=node->right; // Simpan anak kanan
        free(node);                  // Hapus node
        return r;                    // Return anak kanan
    }
    
    node->left = extract(node->left); // Rekursif ke anak kiri
    node->height = 1 + max(height(node->left), height(node->right)); // Update tinggi
    int bf = balance(node); // Hitung balance factor
    
    // Cek imbalance setelah extract
    if(bf > 1 && balance(node->left) >= 0) return rotateright(node); // LL
    if(bf > 1 && balance(node->left) <0){ node->left = rotateleft(node->left); return rotateright(node);} // LR
    if(bf < -1 && balance(node->right) <= 0) return rotateleft(node); // RR
    if(bf < -1 && balance(node->right) > 0){ node->right = rotateright(node->right); return rotateleft(node);} // RL
    
    return node; // Return node yang sudah seimbang
}

// Traversal inorder untuk cetak isi pohon
void inorder(struct tnode *node, int *first){
    if(!node) return; // Jika kosong, berhenti
    inorder(node->left, first); // Rekursif ke kiri
    
    if(*first){ // Node pertama → cetak tanpa koma
        printf("%s", node->id);
        *first = 0;
    }else{      // Node berikutnya → cetak dengan koma + spasi
        printf(", %s", node->id);
    }
    
    inorder(node->right, first); // Rekursif ke kanan
}

// Fungsi utama
int main(){
    int n; 
    scanf("%d", &n); // Input jumlah operasi
    
    for(int i = 0; i<n; i++){ // Loop sebanyak n operasi
        char op;
        scanf(" %c", &op); // Input jenis operasi (I atau E)
        
        if(op == 'I'){ // Jika Insert
            char id[10];
            float fuel;
            int dist;
            scanf("%s %f %d",id,&fuel,&dist); // Input data node
            root = insert(root,id,fuel,dist); // Masukkan ke AVL
        }else if(op == 'E'){ // Jika Extract
            int k;
            scanf("%d", &k); // Input jumlah node yang dihapus
            while(k--) root = extract(root); // Hapus node paling kiri sebanyak k kali
        }
    }
    
    int first = 1; // Flag untuk cetak node pertama
    inorder(root, &first); // Cetak isi pohon dengan inorder traversal
    printf("\n"); // Tambahkan newline di akhir output
    
    return 0; // Program selesai
}
